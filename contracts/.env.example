# =============================================================================
# Contracts environment
# =============================================================================
# Copy to `.env` (which is gitignored) and fill in.
# This file is sourced in the deploy runbook via `export $(grep -v '^#' .env | xargs)`.
# NEVER commit .env. NEVER paste secrets in chat.

# -----------------------------------------------------------------------------
# BNB testnet RPC — primary + optional backup.
# -----------------------------------------------------------------------------
# Official: https://data-seed-prebsc-1-s1.binance.org:8545
# Alt reliable providers: https://bsc-testnet-rpc.publicnode.com
#                         https://bsc-testnet.public.blastapi.io
BNB_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
BNB_TESTNET_RPC_URL_BACKUP=https://bsc-testnet-rpc.publicnode.com

# -----------------------------------------------------------------------------
# BscScan verification — get a free API key at https://bscscan.com/myapikey
# The same API key works for both mainnet and testnet.
# -----------------------------------------------------------------------------
BSCSCAN_API_KEY=

# -----------------------------------------------------------------------------
# Deployer wallet — DO NOT put a raw private key here.
# Use a Foundry keystore (recommended):
#
#   cast wallet import deployer --interactive
#
# Then pass `--account deployer` to `forge script`. Foundry will prompt for
# the password interactively.
#
# If you absolutely must use a raw key (ephemeral testnet only), put it in
# DEPLOYER_PRIVATE_KEY below and pass `--private-key $DEPLOYER_PRIVATE_KEY`
# to forge. Never use this pattern on mainnet.
# -----------------------------------------------------------------------------
DEPLOYER_ACCOUNT=deployer
# DEPLOYER_PRIVATE_KEY=
